# Inference VM environment for docker-compose.inference.yml
#
# Usage:
#   cp .env.inference.example .env.inference
#   cp ../indian-alt-docproc/.env.example ../indian-alt-docproc/docproc.env
#   # Edit docproc.env: VLLM_BASE_URL=http://host.docker.internal:8001/v1
#   # and set VLLM_API_KEY, VLLM_VISION_MODEL, DOCPROC_API_KEY, and
#   # DOCPROC_MAX_CONCURRENT_OCR=2.
#   docker compose --env-file .env.inference -f docker-compose.inference.yml up -d
#
# Notes:
# - This file is for the inference VM only, not the Django app host.
# - docker-compose.inference.yml reads these variables directly.
# - The Django app should point at the VM's published ports separately.
# - With direct TEI, Django should use:
#   EMBEDDING_BASE_URL=http://YOUR_VM_IP:8081/v1
#   RERANKER_BASE_URL=http://YOUR_VM_IP:8082
# - For Phase 4 without the inference VM, run LM Studio on a home-network PC
#   with a 1024-dimensional embedding model loaded and point the script at:
#   EMBEDDING_BASE_URL=http://YOUR_LM_STUDIO_PC_IP:1234/v1
#   EMBEDDING_MODEL=YOUR_LM_STUDIO_MODEL_NAME

# Shared Hugging Face cache on the VM
HF_CACHE_DIR=/mnt/vllm-cache/huggingface

# -------------------------------------------------------------------
# vLLM planner/chat server
# -------------------------------------------------------------------
VLLM_TEXT_MODEL=Qwen/Qwen3.6-35B-A3B-FP8
VLLM_VISION_MODEL=Qwen/Qwen3-VL-8B-Instruct
VLLM_API_KEY=local-dev-key

# Conservative H100 defaults while all four GPU services share the card.
VLLM_TEXT_GPU_MEMORY_UTILIZATION=0.55
VLLM_TEXT_MAX_MODEL_LEN=32768
VLLM_TEXT_MAX_NUM_SEQS=16
VLLM_VISION_GPU_MEMORY_UTILIZATION=0.22
VLLM_VISION_MAX_MODEL_LEN=8192

# -------------------------------------------------------------------
# TEI embedding server
# -------------------------------------------------------------------
EMBEDDING_MODEL_ID=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_MAX_BATCH_TOKENS=8192

# -------------------------------------------------------------------
# TEI reranker server
# -------------------------------------------------------------------
RERANKER_MODEL_ID=BAAI/bge-reranker-v2-m3
RERANKER_MAX_BATCH_TOKENS=4096

# The docproc container uses these as its Uvicorn worker count. Set
# DOCPROC_MAX_CONCURRENT_OCR=2 in ../indian-alt-docproc/docproc.env.
DOCPROC_WORKERS=2

# -------------------------------------------------------------------
# Optional tuning notes
# -------------------------------------------------------------------
# Typical things you may want to change:
# - VLLM_TEXT_MODEL
# - VLLM_API_KEY
# - VLLM_TEXT_GPU_MEMORY_UTILIZATION
# - VLLM_TEXT_MAX_MODEL_LEN
# - VLLM_TEXT_MAX_NUM_SEQS
# - EMBEDDING_MODEL_ID
# - RERANKER_MODEL_ID
#
# Example larger-context settings for an H100 if the model supports it:
# VLLM_TEXT_GPU_MEMORY_UTILIZATION=0.65
# VLLM_TEXT_MAX_MODEL_LEN=65536
# VLLM_TEXT_MAX_NUM_SEQS=32
#
# Example more conservative settings:
# VLLM_TEXT_GPU_MEMORY_UTILIZATION=0.50
# VLLM_TEXT_MAX_MODEL_LEN=16384
# VLLM_TEXT_MAX_NUM_SEQS=8
