# Inference VM environment for docker-compose.inference.yml
#
# Usage:
#   cp .env.inference.example .env.inference
#   docker compose --env-file .env.inference -f docker-compose.inference.yml up -d
#
# Notes:
# - This file is for the inference VM only, not the Django app host.
# - docker-compose.inference.yml reads these variables directly.
# - The Django app should point at the VM's published ports separately.
# - With direct TEI, Django should use:
#   EMBEDDING_BASE_URL=http://YOUR_VM_IP:8081/v1
#   RERANKER_BASE_URL=http://YOUR_VM_IP:8082

# Shared Hugging Face cache on the VM
HF_CACHE_DIR=/mnt/vllm-cache/huggingface

# -------------------------------------------------------------------
# vLLM planner/chat server
# -------------------------------------------------------------------
VLLM_MODEL=Qwen/Qwen3.6-35B-A3B
VLLM_API_KEY=local-dev-key

# Safer defaults for first boot. Increase after confirming stability.
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_MAX_MODEL_LEN=65536
VLLM_MAX_NUM_SEQS=64

# -------------------------------------------------------------------
# TEI embedding server
# -------------------------------------------------------------------
EMBEDDING_MODEL_ID=Qwen/Qwen3-Embedding-0.6B

# -------------------------------------------------------------------
# TEI reranker server
# -------------------------------------------------------------------
RERANKER_MODEL_ID=BAAI/bge-reranker-v2-m3

# -------------------------------------------------------------------
# Optional tuning notes
# -------------------------------------------------------------------
# Typical things you may want to change:
# - VLLM_MODEL
# - VLLM_API_KEY
# - VLLM_GPU_MEMORY_UTILIZATION
# - VLLM_MAX_MODEL_LEN
# - VLLM_MAX_NUM_SEQS
# - EMBEDDING_MODEL_ID
# - RERANKER_MODEL_ID
#
# Example larger-context settings for an H100 if the model supports it:
# VLLM_GPU_MEMORY_UTILIZATION=0.95
# VLLM_MAX_MODEL_LEN=131072
# VLLM_MAX_NUM_SEQS=64
#
# Example more conservative settings:
# VLLM_GPU_MEMORY_UTILIZATION=0.85
# VLLM_MAX_MODEL_LEN=32768
# VLLM_MAX_NUM_SEQS=32
