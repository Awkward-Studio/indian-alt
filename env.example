# -----------------------------------------------------------------------------
# Indian Alt Backend Environment
# -----------------------------------------------------------------------------
# Copy to `.env` for local development. Railway variables should be configured
# in the Railway dashboard per service.

# -----------------------------------------------------------------------------
# Django / Runtime
# -----------------------------------------------------------------------------
DJANGO_ENVIRONMENT=local
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=True

ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000
SECURE_SSL_REDIRECT=false

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Local default: leave DATABASE_URL empty to use SQLite at SQLITE_PATH.
# Production/Railway: set DATABASE_URL to Railway Postgres.
DATABASE_URL=
SQLITE_PATH=db.sqlite3
DB_SSL_REQUIRE=false
DB_CONN_MAX_AGE=600

# Only needed for local docker-compose Postgres, not for Railway DATABASE_URL.
DB_NAME=indian_alt
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# -----------------------------------------------------------------------------
# Redis / Celery / Channels
# -----------------------------------------------------------------------------
# Railway Redis should provide REDIS_URL. Celery falls back to REDIS_URL unless
# CELERY_BROKER_URL / CELERY_RESULT_BACKEND are explicitly set.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Worker-service-only variables. Keep RUN_AS_WORKER unset/false on the web app.
RUN_AS_WORKER=false
CELERY_POOL=threads
CELERY_CONCURRENCY=2
CELERY_QUEUES=high_priority,low_priority,default
CELERY_LOGLEVEL=info
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_ACKS_LATE=true
CELERY_WORKER_MAX_TASKS_PER_CHILD=25

# -----------------------------------------------------------------------------
# Inference VM
# -----------------------------------------------------------------------------
# Text/planner/analysis model hosted by vLLM.
VLLM_BASE_URL=http://20.244.11.248:8000/v1
VLLM_API_KEY=local-dev-key
VLLM_TEXT_MODEL=Qwen/Qwen3.6-35B-A3B
VLLM_PLANNER_MODEL=Qwen/Qwen3.6-35B-A3B
VLLM_VISION_MODEL=

# Direct TEI embedding service.
EMBEDDING_BASE_URL=http://20.244.11.248:8081/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_TIMEOUT=30

# Direct TEI reranker service.
RERANKER_BASE_URL=http://20.244.11.248:8082
RERANKER_API_KEY=
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TIMEOUT=30

# Optional external document processor. Leave empty to use in-process handlers.
DOC_PROCESSOR_URL=
DOC_PROCESSOR_API_KEY=
DOC_PROCESSOR_TIMEOUT=300

# -----------------------------------------------------------------------------
# Microsoft Graph / OneDrive
# -----------------------------------------------------------------------------
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
GRAPH_API_ENDPOINT=https://graph.microsoft.com/v1.0

# Preferred DMS source config.
DMS_USER_EMAIL=dms-demo@india-alt.com
DMS_SHARED_FOLDER_URL=

# Legacy fallback; only set after verifying the drive/path in Graph.
DMS_DRIVE_ID=
DMS_FOLDER_PATH=

# -----------------------------------------------------------------------------
# Azure VM Control
# -----------------------------------------------------------------------------
# Only needed if the app should start/stop/check the inference VM through Azure.
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_VM_NAME=

# -----------------------------------------------------------------------------
# Bulk / Maintenance Scripts
# -----------------------------------------------------------------------------
PHASE3_SYNTHESIS_WORKERS=8
PHASE3_CONNECTION_POOL_SIZE=64
PHASE3_CONTEXT_SAFE_CHARS=60000
PHASE3_BUCKET_CHARS=45000

# Used only by local sync scripts. Do not set this as app runtime config.
PROD_DATABASE_URL=
PROD_DB_SSL_REQUIRE=false
