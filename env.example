# ---------------------------------------------
# Local / Railway Environment Variables
# ---------------------------------------------

# Django
DJANGO_ENVIRONMENT=local
SECRET_KEY=your-secret-key-here
DEBUG=True

# Hosts / CORS (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1
# Add your Railway backend URL in production, e.g. https://your-app.up.railway.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Database
#
# Default behavior:
# - If USE_SQLITE=true OR DATABASE_URL is empty -> SQLite
# - Else -> DATABASE_URL (Postgres on Railway)
USE_SQLITE=true
SQLITE_PATH=db.sqlite3

# Railway Postgres (recommended for production)
# USE_SQLITE=false
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=
DB_SSL_REQUIRE=true
DB_CONN_MAX_AGE=600

# Legacy Postgres vars (kept for compatibility; prefer DATABASE_URL)
DB_NAME=indian_alt
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Production security (set in Railway Variables when DJANGO_ENVIRONMENT=production)
#
# If your frontend is running locally but calling the Railway backend, include localhost here too:
# CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app,http://localhost:3000
CSRF_TRUSTED_ORIGINS=
SECURE_SSL_REDIRECT=true

# Redis / Celery / Channels
# Railway Redis should populate REDIS_URL automatically when attached.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# External vLLM VM
# Point this at your Azure VM hosting vLLM's OpenAI-compatible server.
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_EMBEDDING_URL=http://localhost:8000/v1
VLLM_API_KEY=
VLLM_TEXT_MODEL=
VLLM_PLANNER_MODEL=
VLLM_VISION_MODEL=
VLLM_EMBEDDING_MODEL=
EMBEDDING_BASE_URL=http://localhost:8081
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_TIMEOUT=30
RERANKER_BASE_URL=http://localhost:8082
RERANKER_API_KEY=
RERANKER_MODEL=
RERANKER_TIMEOUT=30
DOC_PROCESSOR_URL=
DOC_PROCESSOR_API_KEY=
DOC_PROCESSOR_TIMEOUT=300

# Microsoft Graph API / Azure AD Configuration
# Get these values from Azure Portal > Azure Active Directory > App registrations
AZURE_CLIENT_ID=your-azure-client-id-here
AZURE_CLIENT_SECRET=your-azure-client-secret-here
AZURE_TENANT_ID=your-azure-tenant-id-here

# Microsoft Graph API Endpoint (usually don't need to change)
GRAPH_API_ENDPOINT=https://graph.microsoft.com/v1.0

# OneDrive / SharePoint config
# Preferred: use the live shared folder URL and the delegated account that can open it.
DMS_USER_EMAIL=dms-demo@india-alt.com
DMS_SHARED_FOLDER_URL=
#
# Legacy fallback: only set these if you have verified the drive/path in Graph.
DMS_DRIVE_ID=
DMS_FOLDER_PATH=

# Note: Email addresses to monitor are managed via EmailAccount model in the database
# Add them via API: POST /api/emails/accounts/ with {"email": "dms-demo@india-alt.com"}
