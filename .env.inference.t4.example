# T4 inference VM environment for docker-compose.inference.t4.yml
#
# Usage:
#   cp .env.inference.t4.example .env.inference.t4
#   edit .env.inference.t4
#   docker compose --env-file .env.inference.t4 -f docker-compose.inference.t4.yml up -d
#
# Django app settings should point at the VM:
#   VLLM_BASE_URL=http://YOUR_T4_VM_IP:8000/v1
#   VLLM_TEXT_MODEL=<same as VLLM_TEXT_MODEL below>
#   VLLM_PLANNER_MODEL=<same as VLLM_TEXT_MODEL below>
#   EMBEDDING_BASE_URL=http://YOUR_T4_VM_IP:8081/v1
#   EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
#   RERANKER_BASE_URL=http://YOUR_T4_VM_IP:8082
#   RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Shared cache
HF_TOKEN=
HF_CACHE_DIR=/mnt/vllm-cache/huggingface

# vLLM text/planner server.
# Use a quantized 7B/8B/9B-class instruct model on T4. Full precision 14B+
# models are usually not realistic on 16GB VRAM.
VLLM_IMAGE=vllm/vllm-openai:latest
VLLM_API_KEY=local-dev-key
VLLM_PORT=8000
VLLM_TEXT_MODEL=mradermacher/Qwen3.5-9B-Claude-4.6-HighIQ-INSTRUCT-HERETIC-UNCENSORED-GGUF
VLLM_DTYPE=half
VLLM_GPU_MEMORY_UTILIZATION=0.82
VLLM_MAX_MODEL_LEN=8192
VLLM_MAX_NUM_SEQS=4
VLLM_MAX_NUM_BATCHED_TOKENS=8192
VLLM_SWAP_SPACE=8
VLLM_CPU_OFFLOAD_GB=0
NVIDIA_VISIBLE_DEVICES=all

# TEI CPU services. Keep these on CPU for T4 so vLLM owns GPU memory.
TEI_IMAGE=ghcr.io/huggingface/text-embeddings-inference:cpu-1.9

EMBEDDING_PORT=8081
EMBEDDING_MODEL_ID=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_MAX_BATCH_TOKENS=4096

RERANKER_PORT=8082
RERANKER_MODEL_ID=BAAI/bge-reranker-v2-m3
RERANKER_MAX_BATCH_TOKENS=2048
